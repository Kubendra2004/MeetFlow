# ── MeetFlow Enviroment Variables ──
# Copy this to .env and fill in your actual credentials.
# DO NOT commit your .env file to version control.

# Groq API Key (AI Analysis)
GROQ_API_KEY="your_groq_api_key_here"

# Twilio Credentials (WhatsApp Notifications)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"

# VTU Internship Portal Login (Auto-Diary)
VTU_USERNAME="your-vtu-email@gmail.com"
VTU_PASSWORD="your-vtu-password"
